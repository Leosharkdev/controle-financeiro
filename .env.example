# Configurações do backend
PORT=5000
NODE_ENV=production
JWT_SECRET=uma_chave_secreta_forte

# Banco de dados PostgreSQL (Render fornece automaticamente)
DATABASE_URL=postgresql://usuario:senha@host:porta/database

# Configurações de email SMTP
SMTP_HOST=smtp.exemplo.com
SMTP_PORT=587
SMTP_USER=seu@usuario.com
SMTP_PASS=sua_senha_do_smtp
EMAIL_FROM="Controle Financeiro" <no-reply@controlefinanceiro.app>

# URL do backend para gerar links de verificação
BACKEND_URL=https://controle-financeiro-ipva.onrender.com
